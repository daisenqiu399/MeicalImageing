# AI Proxy Configuration
# Copy to .env for local development. Never commit real secrets.

# Provider selection
AI_PROVIDER=kimi

# API key for the upstream model provider
AI_API_KEY=your-api-key-here

# Optional Kimi-compatible defaults
AI_BASE_URL=https://api.moonshot.cn/v1
AI_MODEL=kimi-k2.5
AI_TEMPERATURE=

# Local AI proxy port
AI_PROXY_PORT=3001

# Request timeout in milliseconds
AI_TIMEOUT_MS=20000

# Keep PHI stripping enabled unless you have a strong reason not to
AI_REDACT_PHI=true

# Optional logging and rate limiting
LOG_LEVEL=info
RATE_LIMIT=60

# Backward compatibility aliases
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
PROXY_PORT=3001
